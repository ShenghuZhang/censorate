# Application
APP_NAME=Censorate Management System
API_PREFIX=/api/v1
DEBUG=true

# Database
DATABASE_URL=postgresql://stratos:change-me@localhost:5432/stratos
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
POSTGRES_USER=stratos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stratos

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Services
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20240620
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepAgent
DEEPAGENT_API_URL=http://localhost:8001
DEEPAGENT_API_KEY=your-deepagent-api-key

# Hermes
HERMES_PORT=8642
HERMES_API_SERVER_KEY=replace-with-a-long-random-secret
HERMES_GATEWAY_ALLOW_ALL_USERS=false
HERMES_DASHBOARD=1

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_NAME=censorate
MINIO_SKILLS_BUCKET_NAME=censorate-skills
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

# GitHub
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY=your-github-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Lark (Feishu)
LARK_APP_ID=your-lark-app-id
LARK_APP_SECRET=your-lark-app-secret
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8216/api/v1

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
STITCH_ACCESS_TOKEN=your-stitch-token

# Init Demo - Enable/disable demo data initialization (default: true)
INIT_DEMO_ENABLED=true
