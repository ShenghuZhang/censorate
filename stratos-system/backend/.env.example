# Application
APP_NAME=Stratos Management System
API_PREFIX=/api/v1
DEBUG=true
ALLOWED_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1","0.0.0.0"]

# Database
DATABASE_URL=postgresql://stratos:stratos123@localhost:5432/stratos
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT - Generate a strong secret using: openssl rand -hex 32
JWT_SECRET_KEY=your-strong-secret-key-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# AI Services
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20240620
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepAgent
DEEPAGENT_API_URL=http://localhost:8001
DEEPAGENT_API_KEY=your-deepagent-api-key

# GitHub
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY=your-github-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Lark (Feishu)
LARK_APP_ID=your-lark-app-id
LARK_APP_SECRET=your-lark-app-secret
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=
